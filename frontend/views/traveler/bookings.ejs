<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <script>tailwind.config={theme:{extend:{colors:{primary:{500:'#0ea5e9',600:'#0284c7',700:'#0369a1'},accent:{500:'#f97316',600:'#ea580c'},dark:{800:'#1e293b',900:'#0f172a',950:'#020617'}},fontFamily:{sans:['Inter','sans-serif'],display:['Playfair Display','serif']}}}}</script>
  <style>
    body{font-family:'Inter',sans-serif;}
    .glass{background:rgba(255,255,255,0.07);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.12);}
    .glass-dark{background:rgba(15,23,42,0.8);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);}
    .gradient-text{background:linear-gradient(135deg,#38bdf8,#f97316);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .btn-primary{background:linear-gradient(135deg,#0ea5e9,#0369a1);transition:all 0.3s;}
    .btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(14,165,233,0.45);}
    .nav-link{position:relative;}.nav-link::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:2px;background:linear-gradient(90deg,#38bdf8,#f97316);transition:width 0.3s;}.nav-link:hover::after{width:100%;}
    .badge{display:inline-flex;align-items:center;padding:2px 10px;border-radius:999px;font-size:0.7rem;font-weight:600;text-transform:uppercase;}
    ::-webkit-scrollbar{width:6px;}::-webkit-scrollbar-track{background:#0f172a;}::-webkit-scrollbar-thumb{background:#0ea5e9;border-radius:3px;}
  </style>
</head>
<body class="bg-dark-950 text-slate-100 min-h-screen">
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="glass-dark px-6 py-10 border-b border-white/5">
  <div class="max-w-7xl mx-auto">
    <h1 class="font-display text-4xl font-bold text-white mb-2">My <span class="gradient-text">Bookings</span></h1>
    <p class="text-slate-400">Manage all your travel bookings in one place</p>
  </div>
</div>

<div class="max-w-7xl mx-auto px-6 py-10">
  <% if (bookings.length === 0) { %>
  <div class="text-center py-20 glass rounded-3xl">
    <i class="fas fa-suitcase-rolling text-7xl text-slate-700 mb-5 block"></i>
    <h3 class="text-white text-2xl font-bold mb-2">No Bookings Yet!</h3>
    <p class="text-slate-400 mb-8">Start exploring and book your first trip</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/traveler/trips" class="btn-primary px-6 py-3 rounded-xl text-white font-semibold flex items-center gap-2">
        <i class="fas fa-search"></i> Browse Trips
      </a>
      <a href="/traveler/plan-trip" class="glass px-6 py-3 rounded-xl text-white font-semibold flex items-center gap-2 hover:bg-white/10 transition-all">
        <i class="fas fa-magic"></i> Plan a Trip
      </a>
    </div>
  </div>
  <% } else { %>
  <div class="space-y-4">
    <% bookings.forEach(booking => { %>
    <div class="glass-dark rounded-2xl overflow-hidden">
      <div class="p-6">
        <div class="flex items-start justify-between flex-wrap gap-4">
          <div class="flex items-start gap-4">
            <!-- Type Icon -->
            <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 <%= booking.bookingType==='hotel'?'bg-purple-500/15':booking.bookingType==='transport'?'bg-blue-500/15':'bg-sky-500/15' %>">
              <i class="<%= booking.bookingType==='hotel'?'fas fa-hotel text-purple-400':booking.bookingType==='transport'?'fas fa-bus-alt text-blue-400':'fas fa-map-marked-alt text-sky-400' %> text-xl"></i>
            </div>
            <div>
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <h3 class="font-bold text-white">
                  <% if (booking.bookingType==='trip' && booking.trip) { %><%= booking.trip.title %>
                  <% } else if (booking.bookingType==='hotel' && booking.hotel) { %><%= booking.hotel.name %>
                  <% } else if (booking.bookingType==='transport' && booking.transport) { %><%= booking.transport.name %>
                  <% } else { %>Unknown Booking<% } %>
                </h3>
                <span class="badge <%= booking.bookingType==='hotel'?'bg-purple-500/20 text-purple-400':booking.bookingType==='transport'?'bg-blue-500/20 text-blue-400':'bg-sky-500/20 text-sky-400' %>">
                  <%= booking.bookingType %>
                </span>
              </div>
              <div class="flex flex-wrap gap-3 text-sm text-slate-400 mt-1">
                <% if (booking.bookingType==='hotel' && booking.hotel) { %>
                  <span><i class="fas fa-map-marker-alt text-sky-400 mr-1"></i><%= booking.hotel.location %></span>
                <% } %>
                <% if (booking.bookingType==='transport' && booking.transport) { %>
                  <span><i class="fas fa-route text-sky-400 mr-1"></i><%= booking.transport.from %> → <%= booking.transport.to %></span>
                <% } %>
                <% if (booking.checkIn) { %>
                  <span><i class="fas fa-calendar text-sky-400 mr-1"></i><%= new Date(booking.checkIn).toLocaleDateString('en-IN') %> → <%= new Date(booking.checkOut).toLocaleDateString('en-IN') %></span>
                <% } %>
                <span><i class="fas fa-users text-sky-400 mr-1"></i><%= booking.guests %> guest(s)</span>
                <span><i class="fas fa-clock text-sky-400 mr-1"></i><%= new Date(booking.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
              </div>
            </div>
          </div>
          <div class="text-right">
            <div class="text-2xl font-bold text-white">₹<%= booking.totalCost.toLocaleString() %></div>
            <div class="flex gap-2 mt-2 flex-wrap justify-end">
              <span class="badge <%= booking.status==='confirmed'?'bg-green-500/20 text-green-400':booking.status==='cancelled'?'bg-red-500/20 text-red-400':'bg-yellow-500/20 text-yellow-400' %>">
                <i class="fas fa-circle text-xs mr-1"></i> <%= booking.status %>
              </span>
              <span class="badge <%= booking.paymentStatus==='paid'?'bg-emerald-500/20 text-emerald-400':'bg-orange-500/20 text-orange-400' %>">
                💳 <%= booking.paymentStatus %>
              </span>
            </div>
          </div>
        </div>
        <% if (booking.specialRequests) { %>
          <div class="mt-3 glass px-3 py-2 rounded-lg text-xs text-slate-400">
            <i class="fas fa-sticky-note text-yellow-400 mr-1"></i> <%= booking.specialRequests %>
          </div>
        <% } %>
        <% if (booking.status === 'confirmed') { %>
        <div class="mt-4">
          <form action="/traveler/bookings/cancel/<%= booking._id %>" method="POST" onsubmit="return confirm('Cancel this booking?')">
            <button type="submit" class="glass px-4 py-2 rounded-xl text-red-400 hover:bg-red-500/10 text-sm transition-all border border-red-500/20 hover:border-red-500/40">
              <i class="fas fa-times mr-1"></i> Cancel Booking
            </button>
          </form>
        </div>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
</body>
</html>
