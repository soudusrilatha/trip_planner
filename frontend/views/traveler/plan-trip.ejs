<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <script>tailwind.config={theme:{extend:{colors:{primary:{50:'#f0f9ff',100:'#e0f2fe',500:'#0ea5e9',600:'#0284c7',700:'#0369a1',900:'#0c4a6e'},accent:{400:'#fb923c',500:'#f97316',600:'#ea580c'},dark:{800:'#1e293b',900:'#0f172a',950:'#020617'}},fontFamily:{sans:['Inter','sans-serif'],display:['Playfair Display','serif']}}}}</script>
  <link rel="stylesheet" href="/css/style.css"/>
  <script src="/js/main.js" defer></script>
</head>
<body class="bg-dark-950 text-slate-100 min-h-screen">
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<!-- Header -->
<div class="relative py-16 overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-sky-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-orange-500/8 rounded-full blur-3xl"></div>
  </div>
  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 glass px-4 py-2 rounded-full mb-4 text-sm text-sky-300">
      <i class="fas fa-magic text-purple-400"></i> AI Trip Planner
    </div>
    <h1 class="font-display text-5xl font-bold text-white mb-3">Plan Your <span class="gradient-text">Perfect Trip</span></h1>
    <p class="text-slate-400 text-lg">Tell us your preferences and get a personalized travel plan instantly</p>
  </div>
</div>

<div class="max-w-5xl mx-auto px-6 pb-20">

  <!-- Plan Form -->
  <div class="glass-dark rounded-3xl p-8 mb-10">
    <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
      <i class="fas fa-sliders-h text-sky-400"></i> Enter Your Trip Details
    </h2>
    <form action="/traveler/plan-trip" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Destination *</label>
        <div class="relative">
          <i class="fas fa-map-marker-alt absolute left-3 top-1/2 -translate-y-1/2 text-sky-400 text-sm"></i>
          <input type="text" name="destination" required placeholder="e.g. Goa, Manali, Kerala..." value="<%= plan ? plan.destination : '' %>" class="w-full pl-10 pr-4 py-3 rounded-xl text-sm"/>
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Number of Days *</label>
        <div class="relative">
          <i class="fas fa-calendar-alt absolute left-3 top-1/2 -translate-y-1/2 text-sky-400 text-sm"></i>
          <input type="number" name="days" required min="1" max="30" placeholder="e.g. 5" value="<%= plan ? plan.days : '' %>" class="w-full pl-10 pr-4 py-3 rounded-xl text-sm"/>
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Total Budget (₹) *</label>
        <div class="relative">
          <i class="fas fa-rupee-sign absolute left-3 top-1/2 -translate-y-1/2 text-sky-400 text-sm"></i>
          <input type="number" name="budget" required min="1000" placeholder="e.g. 25000" value="<%= plan ? plan.budget : '' %>" class="w-full pl-10 pr-4 py-3 rounded-xl text-sm"/>
        </div>
        <p class="text-xs text-slate-500 mt-1">Budget: ≤₹15K | Mid: ₹15K–50K | Luxury: ₹50K+</p>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Travel With *</label>
        <select name="travelType" class="w-full py-3 px-4 rounded-xl text-sm">
          <option value="solo" <%= plan && plan.travelType==='solo'?'selected':'' %>>🧍 Solo</option>
          <option value="family" <%= plan && plan.travelType==='family'?'selected':'' %>>👨‍👩‍👧 Family</option>
          <option value="friends" <%= plan && plan.travelType==='friends'?'selected':'' %>>👫 Friends</option>
          <option value="couple" <%= plan && plan.travelType==='couple'?'selected':'' %>>💑 Couple</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Food Preference *</label>
        <select name="foodPreference" class="w-full py-3 px-4 rounded-xl text-sm">
          <option value="any" <%= plan && plan.foodPreference==='any'?'selected':'' %>>🍽️ Any</option>
          <option value="veg" <%= plan && plan.foodPreference==='veg'?'selected':'' %>>🥗 Vegetarian</option>
          <option value="non-veg" <%= plan && plan.foodPreference==='non-veg'?'selected':'' %>>🍗 Non-Vegetarian</option>
        </select>
      </div>
      <div class="md:col-span-1 flex items-end">
        <button type="submit" class="btn-accent w-full py-3 rounded-xl text-white font-bold flex items-center justify-center gap-2">
          <i class="fas fa-magic"></i> Generate My Plan
        </button>
      </div>
    </form>
  </div>

  <!-- Generated Plan -->
  <% if (plan) { %>
  <div class="space-y-6">

    <!-- Plan Header -->
    <div class="glass rounded-3xl p-6 text-center plan-section" style="animation-delay:0.1s">
      <div class="text-5xl mb-3">🗺️</div>
      <h2 class="font-display text-3xl font-bold text-white mb-2">Your Trip to <span class="gradient-text"><%= plan.destination %></span></h2>
      <div class="flex flex-wrap justify-center gap-4 text-sm text-slate-300 mt-3">
        <span class="glass px-3 py-1.5 rounded-full"><i class="fas fa-calendar-alt text-sky-400 mr-1"></i> <%= plan.days %> Days</span>
        <span class="glass px-3 py-1.5 rounded-full"><i class="fas fa-rupee-sign text-green-400 mr-1"></i> ₹<%= plan.budget.toLocaleString() %> budget</span>
        <span class="glass px-3 py-1.5 rounded-full"><i class="fas fa-users text-purple-400 mr-1"></i> <%= plan.travelType %></span>
        <span class="glass px-3 py-1.5 rounded-full"><i class="fas fa-utensils text-orange-400 mr-1"></i> <%= plan.foodPreference %></span>
        <span class="badge <%= plan.budgetCategory==='budget'?'bg-green-500/20 text-green-400':plan.budgetCategory==='luxury'?'bg-purple-500/20 text-purple-400':'bg-sky-500/20 text-sky-400' %>"><%= plan.budgetCategory %></span>
      </div>
    </div>

    <!-- Cost Breakdown -->
    <div class="glass-dark rounded-2xl p-6 plan-section" style="animation-delay:0.2s">
      <h3 class="text-xl font-bold text-white mb-5 flex items-center gap-2"><i class="fas fa-rupee-sign text-green-400"></i> Estimated Cost Breakdown</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-5">
        <% const breakdown = [
          {label:'Accommodation',value:plan.costBreakdown.accommodation,icon:'fas fa-hotel',color:'sky'},
          {label:'Food',value:plan.costBreakdown.food,icon:'fas fa-utensils',color:'orange'},
          {label:'Transport',value:plan.costBreakdown.transport,icon:'fas fa-bus-alt',color:'purple'},
          {label:'Activities',value:plan.costBreakdown.activities,icon:'fas fa-hiking',color:'green'}
        ] %>
        <% breakdown.forEach(b => { %>
        <div class="glass rounded-xl p-4 text-center">
          <i class="<%= b.icon %> text-<%= b.color %>-400 text-xl mb-2 block"></i>
          <div class="text-white font-bold text-lg">₹<%= b.value.toLocaleString() %></div>
          <div class="text-slate-400 text-xs mt-1"><%= b.label %></div>
        </div>
        <% }) %>
      </div>
      <div class="glass rounded-xl p-4 flex items-center justify-between">
        <div class="font-semibold text-white flex items-center gap-2"><i class="fas fa-calculator text-sky-400"></i> Total Estimated Cost</div>
        <div class="text-2xl font-bold gradient-text">₹<%= plan.costBreakdown.total.toLocaleString() %></div>
      </div>
      <% if (plan.costBreakdown.total > plan.budget) { %>
        <div class="mt-3 glass rounded-xl p-3 border border-yellow-500/30 text-yellow-400 text-sm flex items-center gap-2">
          <i class="fas fa-exclamation-triangle"></i> Your estimate exceeds budget. Consider reducing days or choosing budget options.
        </div>
      <% } else { %>
        <div class="mt-3 glass rounded-xl p-3 border border-green-500/30 text-green-400 text-sm flex items-center gap-2">
          <i class="fas fa-check-circle"></i> Great news! Your trip fits within the budget with ₹<%= (plan.budget - plan.costBreakdown.total).toLocaleString() %> to spare.
        </div>
      <% } %>
    </div>

    <!-- Matching Trips -->
    <% if (plan.trips && plan.trips.length > 0) { %>
    <div class="glass-dark rounded-2xl p-6 plan-section" style="animation-delay:0.3s">
      <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2"><i class="fas fa-route text-sky-400"></i> Matching Trip Packages</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% plan.trips.slice(0,4).forEach(t => { %>
        <div class="glass rounded-xl p-4 flex items-start gap-3">
          <div class="w-10 h-10 rounded-xl bg-sky-500/15 flex items-center justify-center flex-shrink-0 text-xl">
            <% const icons={beach:'🏖️',adventure:'⛰️',heritage:'🏰',nature:'🌿',city:'🏙️'} %>
            <%= icons[t.category]||'🗺️' %>
          </div>
          <div class="flex-1 min-w-0">
            <h4 class="font-semibold text-white text-sm"><%= t.title %></h4>
            <p class="text-sky-400 text-xs mt-0.5"><%= t.days %> days · ₹<%= t.budgetMin.toLocaleString() %>+</p>
            <p class="text-slate-400 text-xs mt-1 line-clamp-1"><%= t.description %></p>
          </div>
          <a href="/traveler/trips/<%= t._id %>" class="text-sky-400 hover:text-sky-300 text-sm flex-shrink-0"><i class="fas fa-arrow-right"></i></a>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Recommended Hotels -->
      <% if (plan.hotels && plan.hotels.length > 0) { %>
      <div class="glass-dark rounded-2xl p-6 plan-section" style="animation-delay:0.4s">
        <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2"><i class="fas fa-hotel text-purple-400"></i> Suggested Hotels</h3>
        <div class="space-y-3">
          <% plan.hotels.forEach(h => { %>
          <div class="glass rounded-xl p-3 flex items-center justify-between">
            <div>
              <div class="font-semibold text-white text-sm"><%= h.name %></div>
              <div class="text-xs text-slate-400"><%= h.location %> · ⭐ <%= h.rating %></div>
            </div>
            <div class="text-right">
              <div class="text-white font-bold text-sm">₹<%= h.pricePerNight.toLocaleString() %></div>
              <div class="text-xs text-slate-500">/night</div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Transport Options -->
      <% if (plan.transports && plan.transports.length > 0) { %>
      <div class="glass-dark rounded-2xl p-6 plan-section" style="animation-delay:0.45s">
        <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2"><i class="fas fa-bus-alt text-blue-400"></i> Transport Options</h3>
        <div class="space-y-3">
          <% const tIcons={flight:'✈️',train:'🚆',bus:'🚌',cab:'🚕','bike-rental':'🏍️','car-rental':'🚗',ferry:'⛵'} %>
          <% plan.transports.forEach(t => { %>
          <div class="glass rounded-xl p-3 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="text-xl"><%= tIcons[t.type]||'🚌' %></span>
              <div>
                <div class="font-semibold text-white text-sm"><%= t.name %></div>
                <div class="text-xs text-slate-400"><%= t.from %> → <%= t.to %> · <%= t.duration %></div>
              </div>
            </div>
            <div class="text-white font-bold text-sm">₹<%= t.cost.toLocaleString() %></div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Local Food & Tips -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% if (plan.localFood && plan.localFood.length > 0) { %>
      <div class="glass-dark rounded-2xl p-6 plan-section" style="animation-delay:0.5s">
        <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2"><i class="fas fa-utensils text-orange-400"></i> Local Food to Try</h3>
        <div class="space-y-2">
          <% plan.localFood.forEach(f => { %>
          <div class="flex items-center gap-3 glass px-3 py-2.5 rounded-xl">
            <span class="text-orange-400">🍴</span>
            <span class="text-slate-200 text-sm"><%= f %></span>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% if (plan.tips && plan.tips.length > 0) { %>
      <div class="glass-dark rounded-2xl p-6 plan-section" style="animation-delay:0.55s">
        <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2"><i class="fas fa-lightbulb text-yellow-400"></i> Travel Tips</h3>
        <div class="space-y-2">
          <% plan.tips.slice(0,6).forEach(tip => { %>
          <div class="flex items-start gap-2 text-sm text-slate-300">
            <span class="flex-shrink-0 mt-0.5"><%= tip.charAt(0) %></span>
            <span><%= tip.slice(2) %></span>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- CTA -->
    <div class="text-center glass-dark rounded-2xl p-8 plan-section" style="animation-delay:0.6s">
      <h3 class="text-2xl font-bold text-white mb-2">Ready to Book? 🎉</h3>
      <p class="text-slate-400 mb-6">Explore our full trip packages, book hotels and transport</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/traveler/trips?destination=<%= plan.destination %>" class="btn-primary px-6 py-3 rounded-xl text-white font-semibold flex items-center gap-2">
          <i class="fas fa-search"></i> Find Trips to <%= plan.destination %>
        </a>
        <% if (!user) { %>
        <a href="/auth/register" class="btn-accent px-6 py-3 rounded-xl text-white font-semibold flex items-center gap-2">
          <i class="fas fa-user-plus"></i> Sign Up to Book
        </a>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
<script>
// Trigger plan-section animations
document.querySelectorAll('.plan-section').forEach((el, i) => {
  setTimeout(() => { el.style.animationPlayState = 'running'; }, i * 100);
});
</script>
</body>
</html>
