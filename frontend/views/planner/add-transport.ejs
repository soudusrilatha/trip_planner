<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <script>tailwind.config={theme:{extend:{colors:{primary:{500:'#0ea5e9',600:'#0284c7',700:'#0369a1'},accent:{500:'#f97316',600:'#ea580c'},dark:{800:'#1e293b',900:'#0f172a',950:'#020617'}},fontFamily:{sans:['Inter','sans-serif'],display:['Playfair Display','serif']}}}}</script>
  <style>
    body{font-family:'Inter',sans-serif;}
    .glass{background:rgba(255,255,255,0.07);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.12);}
    .glass-dark{background:rgba(15,23,42,0.85);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);}
    .gradient-text{background:linear-gradient(135deg,#38bdf8,#f97316);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .btn-primary{background:linear-gradient(135deg,#0ea5e9,#0369a1);transition:all 0.3s;}
    .btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(14,165,233,0.45);}
    .nav-link{position:relative;}.nav-link::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:2px;background:linear-gradient(90deg,#38bdf8,#f97316);transition:width 0.3s;}.nav-link:hover::after{width:100%;}
    input,select,textarea{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);color:#e2e8f0;}
    input:focus,select:focus,textarea:focus{outline:none;border-color:#0ea5e9;box-shadow:0 0 0 3px rgba(14,165,233,0.2);}
    select option{background:#1e293b;}
    label.form-label{display:block;font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#94a3b8;margin-bottom:0.5rem;}
    ::-webkit-scrollbar{width:6px;}::-webkit-scrollbar-track{background:#0f172a;}::-webkit-scrollbar-thumb{background:#0ea5e9;border-radius:3px;}
  </style>
</head>
<body class="bg-dark-950 text-slate-100 min-h-screen">
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="max-w-3xl mx-auto px-6 py-10">
  <div class="flex items-center gap-3 mb-8">
    <a href="/planner/dashboard" class="glass w-9 h-9 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors">
      <i class="fas fa-arrow-left text-sm"></i>
    </a>
    <div>
      <h1 class="font-display text-3xl font-bold text-white"><%= transport ? 'Edit' : 'Add New' %> <span class="gradient-text">Transport</span></h1>
      <p class="text-slate-400 text-sm mt-1">Add a transport option for travelers</p>
    </div>
  </div>

  <% if (messages.error && messages.error.length > 0) { %>
    <div class="mb-6 glass px-4 py-3 rounded-xl border border-red-500/30 text-red-400 text-sm flex items-center gap-2">
      <i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %>
    </div>
  <% } %>

  <form action="<%= transport ? '/planner/edit-transport/'+transport._id : '/planner/add-transport' %>" method="POST" class="space-y-6">

    <div class="glass-dark rounded-2xl p-6">
      <h2 class="text-lg font-bold text-white mb-5 flex items-center gap-2"><i class="fas fa-bus-alt text-blue-400"></i> Transport Details</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label class="form-label">Transport Name *</label>
          <input type="text" name="name" required placeholder="e.g. IndiGo Delhi-Goa Flight" value="<%= transport ? transport.name : '' %>" class="w-full px-4 py-3 rounded-xl text-sm"/>
        </div>
        <div>
          <label class="form-label">Type *</label>
          <select name="type" class="w-full px-4 py-3 rounded-xl text-sm">
            <option value="flight" <%= transport && transport.type==='flight'?'selected':'' %>>✈️ Flight</option>
            <option value="train" <%= transport && transport.type==='train'?'selected':'' %>>🚆 Train</option>
            <option value="bus" <%= !transport || transport.type==='bus'?'selected':'' %>>🚌 Bus</option>
            <option value="cab" <%= transport && transport.type==='cab'?'selected':'' %>>🚕 Cab</option>
            <option value="bike-rental" <%= transport && transport.type==='bike-rental'?'selected':'' %>>🏍️ Bike Rental</option>
            <option value="car-rental" <%= transport && transport.type==='car-rental'?'selected':'' %>>🚗 Car Rental</option>
            <option value="ferry" <%= transport && transport.type==='ferry'?'selected':'' %>>⛵ Ferry</option>
          </select>
        </div>
        <div>
          <label class="form-label">From *</label>
          <div class="relative">
            <i class="fas fa-map-pin absolute left-3 top-1/2 -translate-y-1/2 text-green-400 text-sm"></i>
            <input type="text" name="from" required placeholder="e.g. New Delhi" value="<%= transport ? transport.from : '' %>" class="w-full pl-9 pr-4 py-3 rounded-xl text-sm"/>
          </div>
        </div>
        <div>
          <label class="form-label">To *</label>
          <div class="relative">
            <i class="fas fa-map-pin absolute left-3 top-1/2 -translate-y-1/2 text-red-400 text-sm"></i>
            <input type="text" name="to" required placeholder="e.g. Goa" value="<%= transport ? transport.to : '' %>" class="w-full pl-9 pr-4 py-3 rounded-xl text-sm"/>
          </div>
        </div>
        <div>
          <label class="form-label">Destination City *</label>
          <input type="text" name="destination" required placeholder="e.g. Goa" value="<%= transport ? transport.destination : '' %>" class="w-full px-4 py-3 rounded-xl text-sm"/>
        </div>
        <div>
          <label class="form-label">Duration *</label>
          <div class="relative">
            <i class="fas fa-clock absolute left-3 top-1/2 -translate-y-1/2 text-sky-400 text-sm"></i>
            <input type="text" name="duration" required placeholder="e.g. 2h 30m" value="<%= transport ? transport.duration : '' %>" class="w-full pl-9 pr-4 py-3 rounded-xl text-sm"/>
          </div>
        </div>
        <div>
          <label class="form-label">Cost Per Person (₹) *</label>
          <div class="relative">
            <i class="fas fa-rupee-sign absolute left-3 top-1/2 -translate-y-1/2 text-sky-400 text-sm"></i>
            <input type="number" name="cost" required min="0" placeholder="e.g. 4500" value="<%= transport ? transport.cost : '' %>" class="w-full pl-9 pr-4 py-3 rounded-xl text-sm"/>
          </div>
        </div>
        <div>
          <label class="form-label">Departure Time</label>
          <input type="text" name="departure" placeholder="e.g. 06:30 AM" value="<%= transport ? transport.departure : '' %>" class="w-full px-4 py-3 rounded-xl text-sm"/>
        </div>
        <div>
          <label class="form-label">Arrival Time</label>
          <input type="text" name="arrival" placeholder="e.g. 09:00 AM" value="<%= transport ? transport.arrival : '' %>" class="w-full px-4 py-3 rounded-xl text-sm"/>
        </div>
        <div class="md:col-span-2">
          <label class="form-label">Description</label>
          <textarea name="description" rows="2" placeholder="Brief description of this transport option..." class="w-full px-4 py-3 rounded-xl text-sm resize-none"><%= transport ? transport.description : '' %></textarea>
        </div>
        <div class="md:col-span-2">
          <label class="form-label">Features (comma-separated)</label>
          <input type="text" name="features" placeholder="AC, Meals included, Window seat, USB charging, WiFi" value="<%= transport && transport.features ? transport.features.join(', ') : '' %>" class="w-full px-4 py-3 rounded-xl text-sm"/>
        </div>
      </div>
    </div>

    <div class="flex gap-4">
      <button type="submit" class="btn-primary px-8 py-3.5 rounded-xl text-white font-bold flex items-center gap-2">
        <i class="fas fa-<%= transport ? 'save' : 'plus' %>"></i> <%= transport ? 'Update Transport' : 'Add Transport' %>
      </button>
      <a href="/planner/dashboard" class="glass px-6 py-3.5 rounded-xl text-slate-400 hover:text-white font-semibold transition-all">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
</body>
</html>
